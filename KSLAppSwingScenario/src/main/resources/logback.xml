<?xml version="1.0" encoding="UTF-8"?>
<!--
    App-owned logging config for the KSL Scenario Swing app.

    Routes KSL logging to a file under ~/.ksl/logs/ and keeps the console
    quiet (warnings + errors only).  Without this file the app falls back to
    logback's built-in default (root -> console at DEBUG), which prints every
    INFO line to the IntelliJ/Gradle console and writes no files at all.  The
    apps ship their own config rather than rely on a library's logback.xml,
    which is fragile when several are on the classpath.
-->
<configuration>
    <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{30} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${user.home}/.ksl/logs/ksl-scenario.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${user.home}/.ksl/logs/ksl-scenario.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
            <totalSizeCap>50MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="com.zaxxer.hikari" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="FILE"/>
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
