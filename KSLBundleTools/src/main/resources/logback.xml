<!--
  Logging configuration for the kslpkg CLI tool.

  This file exists so that bundling the kslpkg fat JAR does NOT fall back to
  logback's BasicConfigurator, which writes INFO-level chatter from KSLCore
  (notably RNStreamProvider during descriptor extraction in `kslpkg enrich`)
  to the console.

  Posture: kslpkg is a CLI tool whose data output goes to stdout.  We send
  log output to stderr at WARN-and-above only, so that:
    * Pipelines like `kslpkg inspect foo.jar | grep ...` see only inspect data.
    * Real problems (WARN, ERROR) still surface, but normal operation is silent.

  KSLCore's own logback.xml is deliberately excluded from KSLCore.jar (see
  KSLCore/build.gradle.kts), so there is no merge conflict to resolve here.
-->
<configuration>
    <!-- Suppress logback's own boot-time INFO chatter. -->
    <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>

    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>%-5level %logger{35} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="WARN">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
